# ─────────────────────────────────────────────────────────────────────────────
# .env.example
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose which AI to use for SQL generation:
#   claude  → Anthropic Claude (requires ANTHROPIC_API_KEY)
#   openai  → OpenAI GPT       (requires OPENAI_API_KEY)
AI_PROVIDER=openai

# ── OpenAI (ChatGPT) ──────────────────────────────────────────────────────────
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Model options and approximate cost per 1M tokens (2026 pricing):
#   gpt-4o-mini  → $0.15 input / $0.60 output  ✅ RECOMMENDED (cheapest)
#   gpt-4o       → $2.50 input / $10.00 output (most capable)
#   gpt-4-turbo  → $10.00 input / $30.00 output
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic Claude (alternative) ───────────────────────────────────────────
# Get your key from: https://console.anthropic.com/
# Only needed if AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...

# ── Google BigQuery ───────────────────────────────────────────────────────────
# GCP project that owns your BigQuery datasets
GCP_PROJECT_ID=arvind-brands-poc

# Default dataset to query
GCP_DATASET=DCOE_Production

# BigQuery data location (US, EU, asia-south1, etc.)
GCP_LOCATION=US

# Path to your GCP service account JSON key file
# Download from: GCP Console → IAM → Service Accounts → Keys
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Microsoft Fabric Data Warehouse ──────────────────────────────────────────
# Only needed if you want to query Fabric alongside BigQuery
FABRIC_SERVER=your-workspace.datawarehouse.fabric.microsoft.com
FABRIC_DATABASE=Arvind_Analytics_Warehouse
FABRIC_CLIENT_ID=your-azure-app-client-id
FABRIC_CLIENT_SECRET=your-azure-app-client-secret
FABRIC_TENANT_ID=your-azure-tenant-id

# ── App Settings ──────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# Maximum BigQuery scan size allowed per query (in GB)
# Queries exceeding this are blocked to protect cost
# At $6.25/TB, 5GB = $0.03 max per query
MAX_BQ_SCAN_GB=5
