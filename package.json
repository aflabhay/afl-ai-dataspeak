{
  "name": "afl-ai-dataspeak",
  "version": "1.0.0",
  "description": "Claude-powered conversational analytics for BigQuery and Microsoft Fabric",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"nodemon server.js\" \"cd frontend && npm run dev\"",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "eslint src/**/*.js server.js",
    "lint:fix": "eslint src/**/*.js server.js --fix",
    "build:frontend": "cd frontend && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@google-cloud/bigquery": "^7.3.0",
    "@lancedb/lancedb": "^0.27.1",
    "compression": "^1.7.4",
    "config": "^3.3.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "mssql": "^10.0.4",
    "openai": "^6.33.0",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70
      }
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
